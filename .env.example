# Spotify App Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify OAuth Redirect URI
# For local development: http://localhost:8000/callback
# For Render.com production: https://your-app-name.onrender.com/callback
SPOTIFY_REDIRECT_URI=http://localhost:8000/callback

# Secret key for signing session cookies
# Generate a strong random string (at least 32 characters)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_this_with_a_strong_random_secret_at_least_32_chars
